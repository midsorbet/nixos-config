{
  "copyOnSelect": false,
  "copyFormatting": "none",
  "trimBlockSelection": true,
  "trimPaste": true,
  "theme": "system",
  "profiles": {
    "defaults": {
      "font": {
        "face": "Maple Mono NF",
        "size": 12
      },
      "cursorShape": "filledBox",
      "colorScheme": {
        "light": "Everforest Light Hard",
        "dark": "Kanagawa Wave"
      }
    }
  },
  "schemes": [
    {
      "name": "Everforest Light Hard",
      "black": "#7a8478",
      "red": "#e67e80",
      "green": "#9ab373",
      "yellow": "#ceaf72",
      "blue": "#7fbbb3",
      "purple": "#d699b6",
      "cyan": "#83c092",
      "white": "#b2af9f",
      "brightBlack": "#a6b0a0",
      "brightRed": "#f85552",
      "brightGreen": "#8da101",
      "brightYellow": "#dfa000",
      "brightBlue": "#3a94c5",
      "brightPurple": "#df69ba",
      "brightCyan": "#35a77c",
      "brightWhite": "#fffbef",
      "background": "#f2efdf",
      "foreground": "#5c6a72",
      "cursorColor": "#f57d26",
      "selectionBackground": "#f0f2d4"
    },
    {
      "name": "Kanagawa Wave",
      "black": "#090618",
      "red": "#c34043",
      "green": "#76946a",
      "yellow": "#c0a36e",
      "blue": "#7e9cd8",
      "purple": "#957fb8",
      "cyan": "#6a9589",
      "white": "#c8c093",
      "brightBlack": "#727169",
      "brightRed": "#e82424",
      "brightGreen": "#98bb6c",
      "brightYellow": "#e6c384",
      "brightBlue": "#7fb4ca",
      "brightPurple": "#938aa9",
      "brightCyan": "#7aa89f",
      "brightWhite": "#dcd7ba",
      "background": "#1f1f28",
      "foreground": "#dcd7ba",
      "cursorColor": "#dcd7ba",
      "selectionBackground": "#dcd7ba"
    }
  ],
  "actions": [
    {
      "command": "commandPalette",
      "keys": "ctrl+shift+p"
    },
    {
      "command": {
        "action": "splitPane",
        "split": "auto",
        "splitMode": "duplicate"
      },
      "keys": "alt+shift+d"
    },
    {
      "command": {
        "action": "moveFocus",
        "direction": "left"
      },
      "keys": "alt+h"
    },
    {
      "command": {
        "action": "moveFocus",
        "direction": "down"
      },
      "keys": "alt+j"
    },
    {
      "command": {
        "action": "moveFocus",
        "direction": "up"
      },
      "keys": "alt+k"
    },
    {
      "command": {
        "action": "moveFocus",
        "direction": "right"
      },
      "keys": "alt+l"
    },
    {
      "command": {
        "action": "resizePane",
        "direction": "left"
      },
      "keys": "alt+shift+h"
    },
    {
      "command": {
        "action": "resizePane",
        "direction": "down"
      },
      "keys": "alt+shift+j"
    },
    {
      "command": {
        "action": "resizePane",
        "direction": "up"
      },
      "keys": "alt+shift+k"
    },
    {
      "command": {
        "action": "resizePane",
        "direction": "right"
      },
      "keys": "alt+shift+l"
    }
  ]
}
